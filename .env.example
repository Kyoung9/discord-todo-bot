# Discord (https://discord.com/developers/applications)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: restrict slash command registration to one guild during development
DISCORD_GUILD_ID=

# Supabase (guild_settings テーブル — マイグレーションは supabase/migrations を参照)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AES-256-GCM: 64 文字 hex（32 byte）推奨。ギルド別 Notion Secret 暗号化に使用
GUILD_SETTINGS_ENCRYPTION_KEY=

# Default Notion integration (ギルドが api_key を保存していない場合のフォールバック)
NOTION_TOKEN=

# Optional LLM defaults (per-guild keys live in Notion AI Keys DB)
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
