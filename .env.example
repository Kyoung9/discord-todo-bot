# Discord (https://discord.com/developers/applications)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: restrict slash command registration to one guild during development
DISCORD_GUILD_ID=

# Supabase (guild_settings テーブル — マイグレーションは supabase/migrations を参照)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AES-256-GCM: 64 文字 hex（32 byte）推奨。ギルド別 Notion Secret 暗号化に使用
GUILD_SETTINGS_ENCRYPTION_KEY=

# Notion Integration Secret — フォールバック用（任意に近い運用も可）
#
# • 各 Discord サーバー（チーム）が**別の** Notion インテグレーションを使う場合:
#   管理者は `/setup-notion` の **api_key** にそのサーバー用 Secret を入れる（Supabase に暗号化保存）。
#   その場合、全ギルドで共通の NOTION_TOKEN は**空のままでも**よい（各ギルドが api_key 済みなら）。
# • NOTION_TOKEN を入れると「api_key を保存していないギルド」は**この 1 本**で Notion に接続する
#   （単一テナント・開発用・全サーバーが同じ Integration を共有するとき向け）。
NOTION_TOKEN=

# Optional LLM defaults (per-guild keys live in Notion AI Keys DB)
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
