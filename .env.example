# Discord (https://discord.com/developers/applications)
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: restrict slash command registration to one guild during development
DISCORD_GUILD_ID=

# Notion integration token (Internal integration). Used to read/write Bot Settings DB rows.
NOTION_TOKEN=

# The Notion database ID where each guild has one Bot Settings row (must match /setup-notion bot_settings_database_id).
NOTION_BOT_SETTINGS_DATABASE_ID=

# Optional LLM defaults (per-guild keys live in Notion AI Keys DB)
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
